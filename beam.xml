<?xml version="1.0"?>
<Container version="2">
  <Name>beam</Name>
  <Repository>ghcr.io/studio2201/beam:latest</Repository>
  <Registry>https://ghcr.io/studio2201/beam</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/beam/issues</Support>
  <Project>https://github.com/studio2201/beam</Project>
  <Overview>High-performance, secure self-hosted file sharing web application built in Rust with an atomic retro pinup interface.</Overview>
  <Category>Tools: MediaServer:Other Network:Web Storage:</Category>
  <WebUI>http://[IP]:[PORT:4401]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/studio2201/beam/main/assets/beam-icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>High-performance, secure self-hosted file sharing web application built in Rust with an atomic retro pinup interface.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4401</HostPort>
        <ContainerPort>4401</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/beam</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4401</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>UPLOAD_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4401" Default="4401" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4401</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/beam" Mode="rw" Description="Persistent file uploads and database directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/beam</Config>
  <Config Name="Security PIN" Target="BEAM_PIN" Default="" Mode="" Description="Optional PIN required for client upload authentication" Type="Variable" Display="always" Required="false" Mask="true"/>
</Container>
