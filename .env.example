#########################################
# SERVER CONFIGURATION
#########################################

# Port for the server (default: 3000)
PORT=4401

# Base URL for the application (default: http://localhost:PORT/) - 
# Must end with a trailing slash. You must update this to the URL you use to access your site.
BASE_URL=http://localhost:4401/

# Environment (development/production)
NODE_ENV=production

#########################################
# FILE UPLOAD SETTINGS
#########################################

# Maximum file size in MB (default: 1024)
MAX_FILE_SIZE=1024

# Total storage limit for the uploads directory in GB (optional)
# If total uploads size exceeds this limit, new uploads will be rejected
# MAX_STORAGE_LIMIT_GB=10
MAX_STORAGE_LIMIT_GB=

# Directory for uploads (Docker/production; optional)
UPLOAD_DIR=

# Directory for uploads (local dev, fallback: './local_uploads')
LOCAL_UPLOAD_DIR=./local_uploads

# Comma-separated list of allowed file extensions (optional, e.g. .jpg,.png,.pdf)
# ALLOWED_EXTENSIONS=.jpg,.png,.pdf
ALLOWED_EXTENSIONS=

#########################################
# SECURITY & PROXIES
#########################################

# PIN protection (4-10 digits, optional)
RUSTDROP_PIN=

# File retention period in days (optional)
# Automatically deletes files older than the specified number of days
# RETENTION_PERIOD_DAYS=7
RETENTION_PERIOD_DAYS=

# Trust proxy headers (X-Forwarded-For) - only enable if behind a reverse proxy (true/false)
TRUST_PROXY=false

# Comma-separated list of trusted proxy IPs (optional, requires TRUST_PROXY=true)
# TRUSTED_PROXY_IPS=172.17.0.1,127.0.0.1
TRUSTED_PROXY_IPS=

#########################################
# UI SETTINGS
#########################################

# Site title displayed in header (default: RustDrop)
RUSTDROP_TITLE=RustDrop

# Enable file explorer listing/download/deletion (true/false)
SHOW_FILE_LIST=false

#########################################
# NOTIFICATION SETTINGS
#########################################

# Apprise URL for notifications (optional)
# APPRISE_URL=tgram://bottoken/chatid
APPRISE_URL=

# Notification message template
APPRISE_MESSAGE=New file uploaded - {filename} ({size}), Storage used {storage}

# Size unit for notifications (B, KB, MB, GB, TB, or Auto; default: Auto)
APPRISE_SIZE_UNIT=Auto

#########################################
# ADVANCED
#########################################

# Enable automatic upload immediately on file selection (true/false, default: false)
AUTO_UPLOAD=false