# Server Configuration
# The port number the backend HTTP server will bind to.
PORT=4401

# The application base URL, essential when deploying behind reverse proxies.
BASE_URL=http://localhost:4401

# Application Settings
# Custom website title rendered in navigation headers, browser tabs, etc.
SITE_TITLE=Beam

# Security: PIN Protection (4-64 characters, leave empty to disable)
# Optional PIN to restrict access to the file sharing interface.
BEAM_PIN=

# CORS Configuration
# Comma-separated list of allowed HTTP request origins. Use * to allow all.
ALLOWED_ORIGINS=*

# Timezone Configuration
# The timezone used for container logs and file timestamps.
TZ=UTC

# Application Specific Settings
# The environment stage, such as production or development.
NODE_ENV=production

# The maximum allowed file size per upload, in Megabytes (MB).
MAX_FILE_SIZE=1024

# The maximum storage capacity limit for the upload directory, in Gigabytes (GB).
MAX_STORAGE_LIMIT_GB=

# Main directory path where uploaded files are stored.
UPLOAD_DIR=

# Local directory path used for uploads during development/local run.
LOCAL_UPLOAD_DIR=./local_uploads

# Comma-separated list of allowed file extensions (e.g. .png,.pdf). Empty means any extension.
ALLOWED_EXTENSIONS=

# Automatically delete uploaded files that are older than this number of days.
RETENTION_PERIOD_DAYS=

# Set to true if the backend is hosted behind a reverse proxy (e.g., Nginx, Cloudflare).
TRUST_PROXY=false

# Comma-separated list of trusted upstream proxy IP addresses or CIDR blocks.
TRUSTED_PROXY_IPS=

# Enable or disable the file explorer listing and deletion interface.
SHOW_FILE_LIST=false

# If true, file uploads begin immediately upon drag-and-drop.
AUTO_UPLOAD=false

# Translation & Rate Limiting
# Enable the multi-language/translation selector in the navigation header.
ENABLE_TRANSLATION=false

# Number of failed PIN authentication attempts permitted before IP lockout.
MAX_ATTEMPTS=5
